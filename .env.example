# Kubernetes Configuration
# Leave empty to use ~/.kube/config or in-cluster config (if running in K8s)
# KUBECONFIG=/path/to/kubeconfig

# Kubernetes cluster name for reporting
K8S_CLUSTER_NAME=production

# Prometheus Configuration
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_TIMEOUT=30

# Application Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Report Output Directory
REPORT_OUTPUT_DIR=./reports

# Optional: Slack Notifications (only if Slack integration is enabled)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Optional: Cloud Provider Specific (for future pricing integration)
# AWS_REGION=us-east-1
# GCP_PROJECT=your-project-id
# AZURE_SUBSCRIPTION_ID=your-subscription-id
